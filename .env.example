# Google OAuth 2.0 Credentials (from Google Cloud Console)
GOOGLE_CLIENT_ID=your_client_id_here
GOOGLE_CLIENT_SECRET=your_client_secret_here
GOOGLE_REDIRECT_URI=http://localhost:3000/api/google/callback
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your_client_id_here

# Development-only database reset toggle.
# Set to true only when schema changes require a fresh database reset.
# Do not enable this in production.
FORCE_DB_RESET=false

# Enables verbose database initialization diagnostics.
# Use only when debugging fresh database initialization issues.
DEBUG_DB_INIT=false

# Enables Vercel Analytics. Disabled by default.
NEXT_PUBLIC_ENABLE_ANALYTICS=false

# Cookie encryption secret (generate with: openssl rand -base64 32)
COOKIE_SECRET=your_secure_random_secret

# Optional diagnostics/auth tokens. Set strong random values before exposing these endpoints.
# DB_HEALTH_TOKEN=your_random_health_token
# API_KEY=your_random_reality_checks_api_key
